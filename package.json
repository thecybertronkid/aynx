{
  "name": "aynx",
  "version": "2.6.3",
  "description": "Universal Media Downloader",
  "author": "Ayan Kashyap",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "node scripts/build.js",
    "package": "node scripts/build.js && electron-builder && node scripts/publish-release.js",
    "download-bin": "node scripts/download-binaries.js"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "electron-store": "^11.0.2",
    "framer-motion": "^11.2.10",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.6",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.21.4",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  },
  "build": {
    "appId": "com.ayankashyap.aynx",
    "productName": "AYNX",
    "copyright": "© 2026 Ayan Kashyap",
    "directories": {
      "output": "release-build"
    },
    "files": [
      "dist/**/*",
      "resources/**/*",
      "!resources/bin/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "publisherName": "Ayan Kashyap",
      "executableName": "AYNX",
      "icon": "resources/icon.png",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AYNX",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "artifactName": "AYNX ${version}.stable.exe"
    }
  }
}
